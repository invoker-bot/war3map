    if ( not ( udg_P2O_Defeat == true ) ) then
        return false
    endif
    if ( not ( udg_P3U_Defeat == true ) ) then
        return false
    endif
    if ( not ( udg_P4N_Defeat == true ) ) then
        return false
    endif
    if ( not ( udg_P5H_Defeat == true ) ) then
        return false
    endif
    if ( not ( udg_Player_GG == false ) ) then
        return false
    endif
    return true
endfunction

