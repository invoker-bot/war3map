function Trig_Map_info_Actions takes nothing returns nothing
    call ForGroupBJ( GetUnitsOfPlayerAndTypeId(Player(4), 'hpea'), function Trig_Map_info_Func001002 )
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 5
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call ForGroupBJ( GetRandomSubGroup(1, udg_H5_P), function Trig_Map_info_Func002Func001A )
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    call SetPlayerStateBJ( Player(0), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( Player(1), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( Player(2), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( Player(3), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( Player(4), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( Player(1), PLAYER_STATE_FOOD_CAP_CEILING, 100 )
    call SetPlayerStateBJ( Player(2), PLAYER_STATE_FOOD_CAP_CEILING, 100 )
    call SetPlayerStateBJ( Player(3), PLAYER_STATE_FOOD_CAP_CEILING, 100 )
    call SetPlayerStateBJ( Player(4), PLAYER_STATE_FOOD_CAP_CEILING, 100 )
    call ForceAddPlayerSimple( Player(1), udg_Com_G )
    call ForceAddPlayerSimple( Player(2), udg_Com_G )
    call ForceAddPlayerSimple( Player(3), udg_Com_G )
    call ForceAddPlayerSimple( Player(4), udg_Com_G )
    call ForceAddPlayerSimple( Player(1), udg_Give_PG )
    call ForceAddPlayerSimple( Player(2), udg_Give_PG )
    call ForceAddPlayerSimple( Player(3), udg_Give_PG )
    call ForceAddPlayerSimple( Player(4), udg_Give_PG )
    call ForceAddPlayerSimple( Player(5), udg_Give_PG )
    set udg_Gold = 3
    set udg_Lumber = 2
    call EnableTrigger( gg_trg_Player_Resorces )
    call ForForce( GetPlayersAll(), function Trig_Map_info_Func026A )
endfunction

