//===========================================================================
function Trig_P2O_T2_Hall_Up_1_Conditions takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(1) ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'ogru' ) ) then
        return false
    endif
    if ( not ( CountLivingPlayerUnitsOfTypeId('ogru', Player(1)) > 4 ) ) then
        return false
    endif
    if ( not ( udg_AI_Trigger != 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2O_T2_Hall_Up_1_Func001Func002C takes nothing returns boolean
    if ( not ( GetPlayerState(Player(1), PLAYER_STATE_RESOURCE_GOLD) >= 315 ) ) then
        return false
    endif
    if ( not ( GetPlayerState(Player(1), PLAYER_STATE_RESOURCE_LUMBER) >= 190 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2O_T2_Hall_Up_1_Actions takes nothing returns nothing
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 99999
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call TriggerSleepAction( 2 )
        if ( Trig_P2O_T2_Hall_Up_1_Func001Func002C() ) then
            call IssueTrainOrderByIdBJ( udg_Hall[1], 'ostr' )
            return
        else
            call DoNothing(  )
        endif
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
endfunction

