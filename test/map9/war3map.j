function InitTrig_P2_First_Hero_Attack takes nothing returns nothing
    set gg_trg_P2_First_Hero_Attack = CreateTrigger(  )
    call TriggerRegisterEnterRectSimple( gg_trg_P2_First_Hero_Attack, gg_rct________000 )
    call TriggerAddCondition( gg_trg_P2_First_Hero_Attack, Condition( function Trig_P2_First_Hero_Attack_Conditions ) )
