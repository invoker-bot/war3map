//===========================================================================
// Trigger: P3U Exp
//===========================================================================
function Trig_P3U_Exp_Func012001001002 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'ugol' )
endfunction

function Trig_P3U_Exp_Conditions takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(2) ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'ugol' ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(GetUnitsInRectMatching(gg_rct_P3U_Exp_Area, Condition(function Trig_P3U_Exp_Func012001001002))) > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P3U_Exp_Actions takes nothing returns nothing
    call CreateNUnitsAtLoc( 1, 'uaco', Player(2), GetRectCenter(gg_rct_P3U_Exp_Worker), bj_UNIT_FACING )
    set udg_P3ExpWorker[1] = GetLastCreatedUnit()
    call RemoveGuardPosition( GetLastCreatedUnit() )
    call CreateNUnitsAtLoc( 1, 'uaco', Player(2), GetRectCenter(gg_rct_P3U_Exp_Worker), bj_UNIT_FACING )
    set udg_P3ExpWorker[2] = GetLastCreatedUnit()
    call RemoveGuardPosition( GetLastCreatedUnit() )
    call CreateNUnitsAtLoc( 5, 'uaco', Player(2), GetRectCenter(gg_rct_P3U_Exp_Worker), bj_UNIT_FACING )
    call IssueBuildOrderByIdLocBJ( udg_P3ExpWorker[1], 'u001', GetRectCenter(gg_rct_P3U_Exp_Tower_1) )
    call IssueBuildOrderByIdLocBJ( udg_P3ExpWorker[2], 'u001', GetRectCenter(gg_rct_P3U_Exp_Tower_2) )
endfunction

