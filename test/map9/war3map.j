    if ( not ( GetPlayerState(Player(2), PLAYER_STATE_RESOURCE_GOLD) < GetPlayerState(Player(3), PLAYER_STATE_RESOURCE_GOLD) ) ) then
        return false
    endif
    if ( not ( GetPlayerState(Player(2), PLAYER_STATE_RESOURCE_GOLD) < GetPlayerState(Player(4), PLAYER_STATE_RESOURCE_GOLD) ) ) then
