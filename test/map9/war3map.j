    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(3) ) ) then
        return false
    endif
    if ( not ( RectContainsUnit(gg_rct_P4N_Hall, GetTriggerUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Unit_Func006Func002Func001Func004C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(4) ) ) then
        return false
    endif
    if ( not ( RectContainsUnit(gg_rct_P5H_Hall, GetTriggerUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Unit_Func006Func002Func001C takes nothing returns boolean
    if ( Trig_Danger_Unit_Func006Func002Func001Func001C() ) then
        return true
    endif
    if ( Trig_Danger_Unit_Func006Func002Func001Func002C() ) then
        return true
    endif
    if ( Trig_Danger_Unit_Func006Func002Func001Func003C() ) then
        return true
    endif
    if ( Trig_Danger_Unit_Func006Func002Func001Func004C() ) then
        return true
    endif
    return false
endfunction

function Trig_Danger_Unit_Func006Func002C takes nothing returns boolean
    if ( not Trig_Danger_Unit_Func006Func002Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Unit_Actions takes nothing returns nothing
    call RemoveGuardPosition( GetTriggerUnit() )
    if ( Trig_Danger_Unit_Func002001() ) then
        call IssuePointOrderByIdLoc( GetTriggerUnit(), String2OrderIdBJ("move"), GetPlayerStartLocationLoc(Player(1)) )
    else
        call DoNothing(  )
    endif
    if ( Trig_Danger_Unit_Func003001() ) then
        call IssuePointOrderByIdLoc( GetTriggerUnit(), String2OrderIdBJ("move"), GetPlayerStartLocationLoc(Player(2)) )
    else
        call DoNothing(  )
    endif
    if ( Trig_Danger_Unit_Func004001() ) then
        call IssuePointOrderByIdLoc( GetTriggerUnit(), String2OrderIdBJ("move"), GetPlayerStartLocationLoc(Player(3)) )
    else
        call DoNothing(  )
    endif
    if ( Trig_Danger_Unit_Func005001() ) then
        call IssuePointOrderByIdLoc( GetTriggerUnit(), String2OrderIdBJ("move"), GetPlayerStartLocationLoc(Player(4)) )
    else
        call DoNothing(  )
    endif
    set udg_Unit = 1
    loop
        exitwhen udg_Unit > 99999
        call TriggerSleepAction( 5.00 )
        if ( Trig_Danger_Unit_Func006Func002C() ) then
            set udg_Unit = 99999
        else
            call DoNothing(  )
        endif
        set udg_Unit = udg_Unit + 1
    endloop
    call RecycleGuardPosition( GetTriggerUnit() )
endfunction

