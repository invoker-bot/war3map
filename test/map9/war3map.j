    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'Hamg' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BM_Attack_Func015C takes nothing returns boolean
    if ( Trig_BM_Attack_Func015Func001C() ) then
        return true
    endif
    if ( Trig_BM_Attack_Func015Func002C() ) then
        return true
    endif
    if ( Trig_BM_Attack_Func015Func003C() ) then
        return true
    endif
    if ( Trig_BM_Attack_Func015Func004C() ) then
        return true
    endif
    return false
endfunction

function Trig_BM_Attack_Conditions takes nothing returns boolean
    if ( not Trig_BM_Attack_Func015C() ) then
        return false
    endif
    return true
endfunction

