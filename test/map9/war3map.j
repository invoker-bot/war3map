function Trig_P5_First_Attack_End_Func002A takes nothing returns nothing
    call RecycleGuardPosition( GetEnumUnit() )
endfunction

function Trig_P5_First_Attack_End_Actions takes nothing returns nothing
    call DestroyTrigger( GetTriggeringTrigger() )
    call ForGroupBJ( GetUnitsOfPlayerAndTypeId(Player(4), 'hwat'), function Trig_P5_First_Attack_End_Func002A )
    call RecycleGuardPosition( udg_Hero[4] )
    call SetPlayerTechResearchedSwap( 'R000', 0, Player(4) )
    set udg_First_Attack[2] = false
endfunction

//===========================================================================
function InitTrig_P5_First_Attack_End takes nothing returns nothing
    set gg_trg_P5_First_Attack_End = CreateTrigger(  )
    call TriggerRegisterTimerEventPeriodic( gg_trg_P5_First_Attack_End, 1.00 )
    call TriggerAddCondition( gg_trg_P5_First_Attack_End, Condition( function Trig_P5_First_Attack_End_Conditions ) )
    call TriggerAddAction( gg_trg_P5_First_Attack_End, function Trig_P5_First_Attack_End_Actions )
endfunction

//===========================================================================
// Trigger: First Attack Real End
//===========================================================================
function Trig_First_Attack_Real_End_Func005C takes nothing returns boolean
    if ( ( udg_First_Attack[1] == true ) ) then
        return true
    endif
    if ( ( udg_First_Attack[2] == true ) ) then
        return true
    endif
    if ( ( udg_First_Attack[3] == true ) ) then
        return true
    endif
    if ( ( udg_First_Attack[4] == true ) ) then
        return true
    endif
    return false
endfunction

function Trig_First_Attack_Real_End_Conditions takes nothing returns boolean
    if ( not Trig_First_Attack_Real_End_Func005C() ) then
        return false
    endif
    return true
endfunction

function Trig_First_Attack_Real_End_Actions takes nothing returns nothing
    call TriggerExecute( gg_trg_P2_First_Attack_End )
    call TriggerExecute( gg_trg_P3_First_Attack_End )
    call TriggerExecute( gg_trg_P4_First_Attack_End )
    call TriggerExecute( gg_trg_P5_First_Attack_End )
endfunction

//===========================================================================
function InitTrig_First_Attack_Real_End takes nothing returns nothing
    set gg_trg_First_Attack_Real_End = CreateTrigger(  )
    call TriggerRegisterTimerEventSingle( gg_trg_First_Attack_Real_End, 240.00 )
    call TriggerAddCondition( gg_trg_First_Attack_Real_End, Condition( function Trig_First_Attack_Real_End_Conditions ) )
    call TriggerAddAction( gg_trg_First_Attack_Real_End, function Trig_First_Attack_Real_End_Actions )
endfunction

//===========================================================================
// Trigger: Danger Item
//===========================================================================
function Trig_Danger_Item_Conditions takes nothing returns boolean
    if ( not ( IsPlayerInForce(GetOwningPlayer(GetTriggerUnit()), udg_Com_G) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'stwp') == true ) ) then
        return false
    endif
    if ( not ( GetUnitLifePercent(GetTriggerUnit()) <= 15.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Item_Actions takes nothing returns nothing
    call UnitUseItemPointLoc( GetTriggerUnit(), GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'stwp'), GetRectCenter(RectFromCenterSizeBJ(GetPlayerStartLocationLoc(GetOwningPlayer(GetTriggerUnit())), 0.00, 0.00)) )
endfunction

//===========================================================================
function InitTrig_Danger_Item takes nothing returns nothing
    set gg_trg_Danger_Item = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Danger_Item, EVENT_PLAYER_UNIT_DAMAGED )
    call TriggerAddCondition( gg_trg_Danger_Item, Condition( function Trig_Danger_Item_Conditions ) )
    call TriggerAddAction( gg_trg_Danger_Item, function Trig_Danger_Item_Actions )
endfunction

//===========================================================================
// Trigger: Danger Unit
//===========================================================================
function Trig_Danger_Unit_Conditions takes nothing returns boolean
    if ( not ( IsPlayerInForce(GetOwningPlayer(GetTriggerUnit()), udg_Com_G) == true ) ) then
        return false
    endif
    if ( not ( GetUnitLifePercent(GetTriggerUnit()) <= 20.00 ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Unit_Func002001 takes nothing returns boolean
    return ( GetOwningPlayer(GetTriggerUnit()) == Player(1) )
endfunction

function Trig_Danger_Unit_Func003001 takes nothing returns boolean
    return ( GetOwningPlayer(GetTriggerUnit()) == Player(2) )
endfunction

function Trig_Danger_Unit_Func004001 takes nothing returns boolean
    return ( GetOwningPlayer(GetTriggerUnit()) == Player(3) )
endfunction

function Trig_Danger_Unit_Func005001 takes nothing returns boolean
    return ( GetOwningPlayer(GetTriggerUnit()) == Player(4) )
endfunction

function Trig_Danger_Unit_Func006Func002Func001Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(1) ) ) then
        return false
    endif
    if ( not ( RectContainsUnit(gg_rct_P2O_Hall, GetTriggerUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Danger_Unit_Func006Func002Func001Func002C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == Player(2) ) ) then
        return false
    endif
    if ( not ( RectContainsUnit(gg_rct_P3U_Hall, GetTriggerUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

