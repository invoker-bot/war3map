//===========================================================================
// Trigger: Melee Initialization
//
// Default melee game initialization for all players
//===========================================================================
function Trig_Melee_Initialization_Actions takes nothing returns nothing
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_083" )
    call TriggerSleepAction( 1.00 )
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_085" )
    call TriggerSleepAction( 1.00 )
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_086" )
    call TriggerSleepAction( 1.00 )
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_087" )
    call TriggerSleepAction( 1.00 )
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_088" )
    call TriggerSleepAction( 1.00 )
    call MeleeStartingVisibility(  )
    call MeleeStartingHeroLimit(  )
    call MeleeGrantHeroItems(  )
    call MeleeStartingResources(  )
    call MeleeClearExcessUnits(  )
    set udg_Player_Race = GetPlayerRace(Player(0))
    call TriggerExecute( gg_trg_Map_info )
    call TriggerExecute( gg_trg_Com_Infro )
    call TriggerExecute( gg_trg_User_Info )
    call SetPlayerAllianceStateBJ( Player(0), Player(5), bj_ALLIANCE_ALLIED_ADVUNITS )
    call SetPlayerAllianceStateBJ( Player(1), Player(5), bj_ALLIANCE_ALLIED_ADVUNITS )
    call SetPlayerAllianceStateBJ( Player(2), Player(5), bj_ALLIANCE_ALLIED_ADVUNITS )
    call SetPlayerAllianceStateBJ( Player(3), Player(5), bj_ALLIANCE_ALLIED_ADVUNITS )
    call SetPlayerAllianceStateBJ( Player(4), Player(5), bj_ALLIANCE_ALLIED_ADVUNITS )
    call SmartCameraPanBJ( Player(5), GetPlayerStartLocationLoc(Player(2)), 0.01 )
    call TriggerSleepAction( 30.00 )
    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_ALWAYSHINT, "TRIGSTR_190" )
    call TriggerSleepAction( 30.00 )
    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_ALWAYSHINT, "TRIGSTR_189" )
    call TriggerSleepAction( 30.00 )
    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_ALWAYSHINT, "TRIGSTR_194" )
endfunction

