//===========================================================================
// Trigger: difficulty Normal
//===========================================================================
function Trig_difficulty_Normal_Conditions takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_diual_button[1] ) ) then
        return false
    endif
    return true
endfunction

function Trig_difficulty_Normal_Actions takes nothing returns nothing
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_031" )
    set udg_difficulty = 1
    call TriggerExecute( gg_trg_Player_Race )
endfunction

//===========================================================================
function InitTrig_difficulty_Normal takes nothing returns nothing
    set gg_trg_difficulty_Normal = CreateTrigger(  )
    call TriggerRegisterDialogEventBJ( gg_trg_difficulty_Normal, udg_diual )
    call TriggerAddCondition( gg_trg_difficulty_Normal, Condition( function Trig_difficulty_Normal_Conditions ) )
    call TriggerAddAction( gg_trg_difficulty_Normal, function Trig_difficulty_Normal_Actions )
endfunction

//===========================================================================
// Trigger: difficulty Hard
//===========================================================================
function Trig_difficulty_Hard_Conditions takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_diual_button[2] ) ) then
        return false
    endif
    return true
endfunction

function Trig_difficulty_Hard_Actions takes nothing returns nothing
    call DisplayTextToForce( GetPlayersAll(), "TRIGSTR_030" )
    set udg_difficulty = 2
    call TriggerExecute( gg_trg_Player_Race )
endfunction

//===========================================================================
function InitTrig_difficulty_Hard takes nothing returns nothing
    set gg_trg_difficulty_Hard = CreateTrigger(  )
    call TriggerRegisterDialogEventBJ( gg_trg_difficulty_Hard, udg_diual )
    call TriggerAddCondition( gg_trg_difficulty_Hard, Condition( function Trig_difficulty_Hard_Conditions ) )
    call TriggerAddAction( gg_trg_difficulty_Hard, function Trig_difficulty_Hard_Actions )
endfunction

//===========================================================================
// Trigger: Player Race
//===========================================================================
function Trig_Player_Race_Func012001 takes nothing returns boolean
    return ( GetPlayerController(Player(0)) == MAP_CONTROL_USER )
endfunction

function Trig_Player_Race_Actions takes nothing returns nothing
    call DialogSetMessageBJ( udg_Player_Race_Diual, "TRIGSTR_024" )
    call DialogAddButtonBJ( udg_Player_Race_Diual, "TRIGSTR_025" )
    set udg_Race_button[1] = GetLastCreatedButtonBJ()
    call DialogAddButtonBJ( udg_Player_Race_Diual, "TRIGSTR_026" )
    set udg_Race_button[2] = GetLastCreatedButtonBJ()
    call DialogAddButtonBJ( udg_Player_Race_Diual, "TRIGSTR_027" )
    set udg_Race_button[3] = GetLastCreatedButtonBJ()
    call DialogAddButtonBJ( udg_Player_Race_Diual, "TRIGSTR_028" )
    set udg_Race_button[4] = GetLastCreatedButtonBJ()
    call DialogAddButtonBJ( udg_Player_Race_Diual, "TRIGSTR_029" )
