    if ( Trig_P2O_Give_Gold_2_Func001C() ) then
        call SetPlayerStateBJ( Player(1), PLAYER_STATE_RESOURCE_GOLD, ( GetPlayerState(Player(1), PLAYER_STATE_RESOURCE_GOLD) - 300 ) )
        call SetPlayerStateBJ( Player(2), PLAYER_STATE_RESOURCE_GOLD, ( GetPlayerState(Player(2), PLAYER_STATE_RESOURCE_GOLD) + 300 ) )
        call ForForce( bj_FORCE_PLAYER[5], function Trig_P2O_Give_Gold_2_Func001Func004002 )
        call TriggerSleepAction( 2 )
