//===========================================================================
// Trigger: User Info
//===========================================================================
function Trig_User_Info_Func003Func002001 takes nothing returns boolean
    return ( udg_Player_Race == RACE_HUMAN )
endfunction

function Trig_User_Info_Func003Func003001 takes nothing returns boolean
    return ( udg_Player_Race == RACE_ORC )
endfunction

function Trig_User_Info_Func003Func004001 takes nothing returns boolean
    return ( udg_Player_Race == RACE_ORC )
endfunction

function Trig_User_Info_Func003Func005001 takes nothing returns boolean
    return ( udg_Player_Race == RACE_UNDEAD )
endfunction

function Trig_User_Info_Func003Func006001 takes nothing returns boolean
    return ( udg_Player_Race == RACE_NIGHTELF )
endfunction

function Trig_User_Info_Func003C takes nothing returns boolean
    if ( not ( GetPlayerController(Player(0)) == MAP_CONTROL_COMPUTER ) ) then
        return false
    endif
    return true
endfunction

function Trig_User_Info_Actions takes nothing returns nothing
    call SmartCameraPanBJ( Player(0), GetPlayerStartLocationLoc(Player(0)), 0.01 )
    call MeleeStartingUnitsForPlayer( udg_Player_Race, Player(0), GetPlayerStartLocationLoc(Player(0)), true )
    if ( Trig_User_Info_Func003C() ) then
        if ( Trig_User_Info_Func003Func002001() ) then
            call StartMeleeAI( Player(0), "human.ai" )
        else
            call DoNothing(  )
        endif
        if ( Trig_User_Info_Func003Func003001() ) then
            call ConditionalTriggerExecute( gg_trg_Player_Hard_Cheat )
        else
            call DoNothing(  )
        endif
        if ( Trig_User_Info_Func003Func004001() ) then
            call StartMeleeAI( Player(0), "war3mapImported\\Monolith_Orc_Hard.ai" )
        else
            call DoNothing(  )
        endif
        if ( Trig_User_Info_Func003Func005001() ) then
            call StartMeleeAI( Player(0), "undead.ai" )
        else
            call DoNothing(  )
        endif
        if ( Trig_User_Info_Func003Func006001() ) then
            call StartMeleeAI( Player(0), "elf.ai" )
        else
            call DoNothing(  )
        endif
    else
        call DoNothing(  )
    endif
    call SetPlayerUnitAvailableBJ( 'u000', false, Player(0) )
    call SetPlayerUnitAvailableBJ( 'u001', false, Player(0) )
    call SetPlayerUnitAvailableBJ( 'e000', false, Player(0) )
    call SetPlayerUnitAvailableBJ( 'ospw', false, Player(0) )
    call SetPlayerUnitAvailableBJ( 'u002', false, Player(0) )
    call SetPlayerUnitAvailableBJ( 'E001', false, Player(0) )
endfunction

