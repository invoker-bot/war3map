    return ( GetOwningPlayer(GetTriggerUnit()) == Player(3) )
endfunction

function Trig_BM_Attack_Actions takes nothing returns nothing
    // 플레이어 2
    if ( Trig_BM_Attack_Func002001() ) then
        set udg_Hero[1] = GetTriggerUnit()
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func003001() ) then
        set udg_First_Attack[1] = true
    else
        call DoNothing(  )
    endif
    // 플레이어 3
    if ( Trig_BM_Attack_Func005001() ) then
        set udg_Hero[2] = GetTriggerUnit()
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func006001() ) then
        set udg_First_Attack[3] = true
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func007001() ) then
        call IssueImmediateOrderById( udg_Hero[2], String2OrderIdBJ("frostarmoron") )
    else
        call DoNothing(  )
    endif
    // 플레이어 4
    if ( Trig_BM_Attack_Func009001() ) then
        set udg_Hero[3] = GetTriggerUnit()
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func010001() ) then
        set udg_First_Attack[4] = true
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func011001() ) then
        call IssueImmediateOrderById( udg_Hero[3], String2OrderIdBJ("flamingarrows") )
    else
        call DoNothing(  )
    endif
    // 플레이어 5
    if ( Trig_BM_Attack_Func013001() ) then
        set udg_Hero[4] = GetTriggerUnit()
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func014001() ) then
        set udg_First_Attack[2] = true
    else
        call DoNothing(  )
    endif
    call SetPlayerTechResearchedSwap( 'R000', 1, GetOwningPlayer(GetTriggerUnit()) )
    call RemoveGuardPosition( GetTriggerUnit() )
    call IssuePointOrderByIdLoc( GetTriggerUnit(), String2OrderIdBJ("move"), GetPlayerStartLocationLoc(Player(0)) )
    if ( Trig_BM_Attack_Func019001() ) then
        call IssuePointOrderByIdLoc( udg_Hero[2], String2OrderIdBJ("attack"), GetPlayerStartLocationLoc(Player(0)) )
    else
        call DoNothing(  )
    endif
    if ( Trig_BM_Attack_Func020001() ) then
        call IssuePointOrderByIdLoc( udg_Hero[3], String2OrderIdBJ("attack"), GetPlayerStartLocationLoc(Player(0)) )
    else
        call DoNothing(  )
    endif
endfunction

