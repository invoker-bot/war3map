function config takes nothing returns nothing
    call SetMapName( "TRIGSTR_000" )
    call SetMapDescription( "TRIGSTR_002" )
    call SetPlayers( 7 )
    call SetTeams( 7 )
    call SetGamePlacement( MAP_PLACEMENT_TEAMS_TOGETHER )

    call DefineStartLocation( 0, 5312.0, 1024.0 )
    call DefineStartLocation( 1, 3200.0, -5056.0 )
    call DefineStartLocation( 2, -5440.0, 1600.0 )
    call DefineStartLocation( 3, -4864.0, -4544.0 )
    call DefineStartLocation( 4, 448.0, 5312.0 )
    call DefineStartLocation( 5, -512.0, -256.0 )
    call DefineStartLocation( 6, -448.0, -256.0 )

    // Player setup
    call InitCustomPlayerSlots(  )
    call InitCustomTeams(  )
    call InitAllyPriorities(  )
endfunction

