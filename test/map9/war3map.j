    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "TRIGSTR_158" )
    call ForGroupBJ( GetUnitsOfPlayerAll(Player(1)), function Trig_P2O_Defeat_Func002002 )
    call CustomDefeatBJ( Player(1), "TRIGSTR_159" )
    set udg_P2O_Defeat = true
    if ( Trig_P2O_Defeat_Func005C() ) then
        call TriggerSleepAction( 2.00 )
        call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "TRIGSTR_195" )
        call TriggerSleepAction( 1.00 )
        call CustomVictoryBJ( Player(0), true, true )
    else
        call DoNothing(  )
    endif
endfunction

