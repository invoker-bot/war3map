function InitTrig_BM_Attack takes nothing returns nothing
    set gg_trg_BM_Attack = CreateTrigger(  )
    call TriggerRegisterEnterRectSimple( gg_trg_BM_Attack, GetPlayableMapRect() )
    call TriggerAddCondition( gg_trg_BM_Attack, Condition( function Trig_BM_Attack_Conditions ) )
    call TriggerAddAction( gg_trg_BM_Attack, function Trig_BM_Attack_Actions )
endfunction

//===========================================================================
// Trigger: P2 First Hero Attack
//===========================================================================
function Trig_P2_First_Hero_Attack_Conditions takes nothing returns boolean
    if ( not ( GetTriggerUnit() == udg_Hero[1] ) ) then
        return false
    endif
    if ( not ( udg_First_Attack[1] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_First_Hero_Attack_Func006Func001Func002C takes nothing returns boolean
    if ( not ( GetUnitStateSwap(UNIT_STATE_MANA, udg_Hero[1]) >= 85.00 ) ) then
        return false
    endif
    if ( not ( BlzGetUnitAbilityCooldownRemaining(udg_Hero[1], 'AOsf') < 1.00 ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(GetUnitsOfPlayerAndTypeId(Player(1), 'osw1')) < 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_First_Hero_Attack_Func006Func001C takes nothing returns boolean
    if ( not ( udg_First_Attack[1] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_First_Hero_Attack_Actions takes nothing returns nothing
    call IssueImmediateOrderBJ( udg_Hero[1], "spiritwolf" )
    call TriggerSleepAction( 28.00 )
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 9999
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_P2_First_Hero_Attack_Func006Func001C() ) then
            call TriggerSleepAction( 3.00 )
            if ( Trig_P2_First_Hero_Attack_Func006Func001Func002C() ) then
                call TriggerSleepAction( 1.00 )
                call IssueImmediateOrderBJ( udg_Hero[1], "spiritwolf" )
            else
                call DoNothing(  )
            endif
        else
            return
        endif
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
endfunction

