        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(( udg_CreepLevel + 2 )), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(( udg_CreepLevel + 2 )), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(( udg_CreepLevel + 2 )), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
    else
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(10), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(10), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(10), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
        call CreateNUnitsAtLoc( 1, ChooseRandomCreepBJ(10), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
    endif
endfunction

