    call TriggerRegisterPlayerChatEvent( gg_trg_ATTACK, Player(0), "GO NOW", true )
    call TriggerRegisterTimerEventPeriodic( gg_trg_ATTACK, 10.00 )
    call TriggerAddAction( gg_trg_ATTACK, function Trig_ATTACK_Actions )
endfunction

