function InitTrig_City_2 takes nothing returns nothing
    set gg_trg_City_2 = CreateTrigger(  )
    call DisableTrigger( gg_trg_City_2 )
    call TriggerRegisterTimerEventPeriodic( gg_trg_City_2, 0.10 )
    call TriggerAddAction( gg_trg_City_2, function Trig_City_2_Actions )
endfunction

