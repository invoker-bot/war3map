//===========================================================================
function Trig_Items_Func001C takes nothing returns boolean
    if ( not ( udg_CreepLevel < 6 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Items_Actions takes nothing returns nothing
    if ( Trig_Items_Func001C() ) then
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[1], 1, 1 )
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[2], 1, 1 )
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
        call DisableTrigger( GetTriggeringTrigger() )
    else
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(3, udg_CreepLevel), ITEM_TYPE_ANY), udg_TheShops[1], 1, 1 )
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(3, udg_CreepLevel), ITEM_TYPE_ANY), udg_TheShops[2], 1, 1 )
        call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(3, udg_CreepLevel), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
        call DisableTrigger( GetTriggeringTrigger() )
    endif
endfunction

