//===========================================================================
// Trigger: Help Me
//===========================================================================
function Trig_Help_Me_Actions takes nothing returns nothing
    call CreateNUnitsAtLoc( 1, udg_Heroes[GetRandomInt(1, 24)], Player(0), GetRandomLocInRect(gg_rct_TheMiddle), bj_UNIT_FACING )
    call ModifyHeroSkillPoints( GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 1 )
    call CreateNUnitsAtLoc( 1, udg_Heroes[GetRandomInt(1, 24)], Player(0), GetRandomLocInRect(gg_rct_TheMiddle), bj_UNIT_FACING )
    call ModifyHeroSkillPoints( GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 1 )
    call CreateNUnitsAtLoc( 1, udg_Heroes[GetRandomInt(1, 24)], Player(0), GetRandomLocInRect(gg_rct_TheMiddle), bj_UNIT_FACING )
    call ModifyHeroSkillPoints( GetLastCreatedUnit(), bj_MODIFYMETHOD_ADD, 1 )
endfunction

