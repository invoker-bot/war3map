    set gg_trg_City_3 = CreateTrigger(  )
    call DisableTrigger( gg_trg_City_3 )
    call TriggerRegisterTimerEventPeriodic( gg_trg_City_3, 0.10 )
    call TriggerAddAction( gg_trg_City_3, function Trig_City_3_Actions )
endfunction

//===========================================================================
// Trigger: City 2
//===========================================================================
function Trig_City_2_Func002C takes nothing returns boolean
    if ( not ( CountUnitsInGroup(GetUnitsInRectOfPlayer(gg_rct_City_2, Player(21))) < 5 ) ) then
        return false
    endif
    return true
endfunction

function Trig_City_2_Actions takes nothing returns nothing
    if ( Trig_City_2_Func002C() ) then
        call CreateNUnitsAtLoc( 1, udg_CityCreepType[GetRandomInt(1, udg_CreepLevel)], Player(21), GetRandomLocInRect(gg_rct_City_2), bj_UNIT_FACING )
    else
        call DisableTrigger( GetTriggeringTrigger() )
    endif
endfunction

