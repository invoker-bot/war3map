//===========================================================================
function Trig_Take_A_Break_Func005A takes nothing returns nothing
    call AdjustPlayerStateBJ( 150, GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD )
    call AdjustPlayerStateBJ( 50, GetEnumPlayer(), PLAYER_STATE_RESOURCE_LUMBER )
endfunction

function Trig_Take_A_Break_Actions takes nothing returns nothing
    set udg_RoundCounter = ( udg_RoundCounter + 1 )
    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, "TRIGSTR_017" )
    call QuestMessageBJ( GetPlayersAll(), bj_QUESTMESSAGE_UPDATED, I2S(udg_RoundCounter) )
    set udg_EliteMercs = 3
    call ForForce( GetPlayersByMapControl(MAP_CONTROL_USER), function Trig_Take_A_Break_Func005A )
    call DisableTrigger( gg_trg_ATTACK )
    call DisableTrigger( gg_trg_Break_Counter )
    call DisableTrigger( gg_trg_ATTACKSend )
    call EnableTrigger( gg_trg_Items )
    call EnableTrigger( gg_trg_Camp_Respawn )
    set udg_BreakCountReal = 0.00
    call StartTimerBJ( udg_RestartTimer, false, 300.00 )
endfunction

