//===========================================================================
// Trigger: Player Startup
//===========================================================================
function Trig_Player_Startup_Func008A takes nothing returns nothing
    call SetPlayerAllianceStateBJ( GetEnumPlayer(), GetEnumPlayer(), bj_ALLIANCE_ALLIED_VISION )
    call SetPlayerAllianceStateBJ( GetEnumPlayer(), Player(22), bj_ALLIANCE_UNALLIED )
    call SetPlayerAllianceStateBJ( Player(22), GetEnumPlayer(), bj_ALLIANCE_UNALLIED )
    call SetPlayerAllianceStateBJ( Player(22), Player(23), bj_ALLIANCE_UNALLIED )
    call CreateNUnitsAtLoc( 1, 'e000', GetEnumPlayer(), GetRectCenter(gg_rct_Hero_Select), bj_UNIT_FACING )
    call CreateFogModifierRectBJ( true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, gg_rct_Hero_Select )
endfunction

function Trig_Player_Startup_Actions takes nothing returns nothing
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call AddItemToStockBJ( ChooseRandomItemExBJ(GetRandomInt(1, ( udg_CreepLevel + 2 )), ITEM_TYPE_ANY), udg_TheShops[GetRandomInt(1, 2)], 1, 1 )
    call EnableTrigger( gg_trg_Camp_Respawn )
    call ForForce( GetPlayersByMapControl(MAP_CONTROL_USER), function Trig_Player_Startup_Func008A )
endfunction

