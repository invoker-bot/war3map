    set gg_trg_Player_Startup = CreateTrigger(  )
    call TriggerRegisterTimerEventSingle( gg_trg_Player_Startup, 1.00 )
    call TriggerAddAction( gg_trg_Player_Startup, function Trig_Player_Startup_Actions )
endfunction

//===========================================================================
// Trigger: Hero Select
//===========================================================================
function Trig_Hero_Select_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetBuyingUnit()) == 'e000' ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetSoldUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Hero_Select_Actions takes nothing returns nothing
    call RemoveUnit( GetBuyingUnit() )
    call SetUnitPositionLoc( GetSoldUnit(), GetRectCenter(gg_rct_TheMiddle) )
endfunction

//===========================================================================
function InitTrig_Hero_Select takes nothing returns nothing
    set gg_trg_Hero_Select = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Hero_Select, EVENT_PLAYER_UNIT_SELL )
    call TriggerAddCondition( gg_trg_Hero_Select, Condition( function Trig_Hero_Select_Conditions ) )
    call TriggerAddAction( gg_trg_Hero_Select, function Trig_Hero_Select_Actions )
endfunction

//===========================================================================
// Trigger: Hero Random
//===========================================================================
function Trig_Hero_Random_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetBuyingUnit()) == 'e000' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'H003' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Hero_Random_Actions takes nothing returns nothing
    call RemoveUnit( GetBuyingUnit() )
