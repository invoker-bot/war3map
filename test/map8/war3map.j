//===========================================================================
// Trigger: Melee Initialization
//
// Default melee game initialization for all players
//===========================================================================
function Trig_Melee_Initialization_Func006A takes nothing returns nothing
    call CreateFogModifierRectBJ( true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, gg_rct_TheMiddle )
    call SetPlayerStateBJ( GetEnumPlayer(), PLAYER_STATE_RESOURCE_HERO_TOKENS, 1 )
    call SetPlayerStateBJ( GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD, 350 )
    call SetPlayerStateBJ( GetEnumPlayer(), PLAYER_STATE_RESOURCE_LUMBER, 150 )
endfunction

function Trig_Melee_Initialization_Actions takes nothing returns nothing
    call MeleeStartingVisibility(  )
    call MeleeStartingAI(  )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_022", "TRIGSTR_023", "ReplaceableTextures\\CommandButtons\\BTNSpellBookBLS.blp" )
    call CreateQuestBJ( bj_QUESTTYPE_OPT_DISCOVERED, "TRIGSTR_024", "TRIGSTR_025", "ReplaceableTextures\\CommandButtons\\BTNSpellBookBLS.blp" )
    call ForForce( GetPlayersAll(), function Trig_Melee_Initialization_Func006A )
endfunction

