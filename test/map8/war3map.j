function Trig_ATTACK_Func001C takes nothing returns boolean
    if ( not ( udg_CreepLevel < 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ATTACK_Actions takes nothing returns nothing
    if ( Trig_ATTACK_Func001C() ) then
        call CreateNUnitsAtLoc( 3, ChooseRandomCreepBJ(GetRandomInt(1, udg_CreepLevel)), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
    else
        call CreateNUnitsAtLoc( 3, ChooseRandomCreepBJ(GetRandomInt(( udg_CreepLevel - 1 ), udg_CreepLevel)), Player(22), GetRectCenter(udg_AttackRandomizer[GetRandomInt(1, 4)]), bj_UNIT_FACING )
    endif
endfunction

